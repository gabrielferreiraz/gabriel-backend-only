# Porta do servidor (padrão: 8080)
PORT=8080

# Chave de autenticação da API — obrigatória em produção
# Todas as rotas (exceto GET /) exigem: Authorization: Bearer <valor>
API_KEY=5a87e192030b249cba6a5780f3a04752edded00a5b9d7a857064a1a7fc77caf2

# URL do webhook para notificação de mensagens recebidas
# Quando configurada, o servidor faz POST para esta URL a cada mensagem individual recebida
# Payload: { userId, instanceId, from, body, timestamp }
# Deixe vazio para desativar
WEBHOOK_URL=https://senderwhats.autosstock.uk/api/webhooks/whatsapp

# Secret de autenticação do webhook — deve ser idêntico ao WEBHOOK_SECRET do sistema Next.js
# Se definido, envia Authorization: Bearer <secret> em cada POST do webhook
# Opcional: se não definido, o POST é enviado sem autenticação
WEBHOOK_SECRET=08937c77d132170449c817a5030487ace6694083733a5249abec0453673be283

# URL base do SenderWhats (Next.js) — sem barra no final
# Usada para notificar entrega (ack=2) e leitura (ack=3) de mensagens enviadas
SENDERWHATS_URL=https://senderwhats.autosstock.uk

# String de conexão PostgreSQL — banco compartilhado com o SenderWhats
# Use um usuário restrito com acesso apenas à tabela whatsapp_sessions
DATABASE_URL=postgresql://api_whatsapp:wh4ts4pp_4pi_2026@82.25.66.22:5786/db-senderwhats?sslmode=disable
